generator client {
  provider     = "prisma-client"
  output       = "../generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

// ==========================================================================
// Enums
// ==========================================================================

enum Role {
  ADMIN
  EDITOR
}

enum ShelterType {
  OFFICIAL
  INFORMAL
}

enum NewsStatus {
  PENDING
  APPROVED
  REJECTED
}

enum SupplyRelationType {
  ACCEPTED
  NEEDED
}

enum BloodType {
  A_POSITIVE
  A_NEGATIVE
  B_POSITIVE
  B_NEGATIVE
  AB_POSITIVE
  AB_NEGATIVE
  O_POSITIVE
  O_NEGATIVE
}

// ==========================================================================
// Autenticación y usuarios
// ==========================================================================

model User {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  email     String   @unique @db.VarChar(255)
  password  String   @db.VarChar(255)
  role      Role     @default(EDITOR)
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  verifiedCollectionCenters CollectionCenter[]
  verifiedShelters          Shelter[]
  verifiedUrgentNeeds       UrgentNeed[]
  verifiedEmergencyNumbers  EmergencyNumber[]
  verifiedHelpLinks         HelpLink[]
  verifiedBloodRequests     BloodRequest[]

  @@map("user")
}

model State {
  id   String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name String @unique @db.VarChar(100)

  aidLevel StateAidLevel?
  cities   City[]

  @@map("state")
}

model StateAidLevel {
  stateAidId String   @id @map("state_aid_id") @db.Uuid
  aidLevel   String   @map("aid_level") @db.VarChar(50)
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt  DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  state State @relation(fields: [stateAidId], references: [id], onDelete: Cascade)

  @@map("state_aid_level")
}

model City {
  id      String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  stateId String @map("state_id") @db.Uuid
  name    String @db.VarChar(120)

  state             State              @relation(fields: [stateId], references: [id], onDelete: Restrict)
  collectionCenters CollectionCenter[]
  shelters          Shelter[]
  hospitals         Hospital[]
  urgentNeeds       UrgentNeed[]
  news              News[]
  emergencyNumbers  EmergencyNumber[]
  bloodRequests     BloodRequest[]

  @@index([stateId, name], map: "city_state_name_key")
  @@map("city")
}

// ==========================================================================
// Centros de acopio, refugios, hospitales
// ==========================================================================

model CollectionCenter {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  cityId       String   @map("city_id") @db.Uuid
  name         String   @db.VarChar(200)
  address      String?  @db.VarChar(300)
  contact      String?  @db.VarChar(150)
  scheduledAt  DateTime @map("scheduled_at") @db.Timestamp(6)
  verified     Boolean  @default(true)
  verifiedById String?  @map("verified_by_id") @db.Uuid
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  city       City                     @relation(fields: [cityId], references: [id], onDelete: Restrict)
  verifiedBy User?                    @relation(fields: [verifiedById], references: [id], onDelete: SetNull)
  supplies   CollectionCenterSupply[]

  @@index([cityId, name], map: "city_key_cc")
  @@index([verified], map: "idx_collection_center_verified")
  @@map("collection_center")
}

model Shelter {
  id           String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  cityId       String      @map("city_id") @db.Uuid
  name         String      @db.VarChar(200)
  address      String?     @db.VarChar(300)
  contact      String?     @db.VarChar(150)
  capacity     String?     @db.VarChar(50)
  type         ShelterType @default(OFFICIAL)
  verified     Boolean     @default(false)
  verifiedById String?     @map("verified_by_id") @db.Uuid
  createdAt    DateTime    @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime    @updatedAt @map("updated_at") @db.Timestamptz(6)

  city       City            @relation(fields: [cityId], references: [id], onDelete: Restrict)
  verifiedBy User?           @relation(fields: [verifiedById], references: [id], onDelete: SetNull)
  supplies   ShelterSupply[]

  @@index([cityId, name], map: "city_key_sh")
  @@index([verified], map: "idx_shelter_verified")
  @@map("shelter")
}

model Hospital {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  cityId    String   @map("city_id") @db.Uuid
  name      String   @db.VarChar(200)
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  city City @relation(fields: [cityId], references: [id], onDelete: Restrict)

  @@unique([cityId, name], map: "hospital_city_name_key")
  @@map("hospital")
}

model UrgentNeed {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  cityId       String   @map("city_id") @db.Uuid
  place        String   @db.VarChar(200)
  address      String?  @db.VarChar(300)
  neededItems  String   @map("needed_items") @db.Text
  contact      String?  @db.VarChar(150)
  verified     Boolean  @default(false)
  verifiedById String?  @map("verified_by_id") @db.Uuid
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  city       City  @relation(fields: [cityId], references: [id], onDelete: Restrict)
  verifiedBy User? @relation(fields: [verifiedById], references: [id], onDelete: SetNull)

  @@index([cityId], map: "idx_urgent_need_city_id")
  @@map("urgent_need")
}

// ==========================================================================
// Solicitudes de sangre
// ==========================================================================

model BloodRequest {
  id           String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  cityId       String      @map("city_id") @db.Uuid
  place        String      @db.VarChar(200)
  address      String?     @db.VarChar(300)
  bloodTypes   BloodType[] @map("blood_types")
  unitsNeeded  Int?        @map("units_needed")
  contact      String?     @db.VarChar(150)
  notes        String?     @db.Text
  verified     Boolean     @default(false)
  verifiedById String?     @map("verified_by_id") @db.Uuid
  createdAt    DateTime    @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime    @updatedAt @map("updated_at") @db.Timestamptz(6)

  city       City  @relation(fields: [cityId], references: [id], onDelete: Restrict)
  verifiedBy User? @relation(fields: [verifiedById], references: [id], onDelete: SetNull)

  @@index([cityId], map: "idx_blood_request_city_id")
  @@index([verified], map: "idx_blood_request_verified")
  @@map("blood_request")
}

// ==========================================================================
// Noticias, números de emergencia, enlaces de ayuda
// ==========================================================================

model News {
  id          String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  title       String     @db.VarChar(250)
  description String     @db.Text
  source      String?    @db.VarChar(500)
  cityId      String?    @map("city_id") @db.Uuid
  status      NewsStatus @default(PENDING)
  createdAt   DateTime   @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime   @updatedAt @map("updated_at") @db.Timestamptz(6)

  city City? @relation(fields: [cityId], references: [id], onDelete: SetNull)

  @@index([cityId], map: "idx_news_state_id")
  @@map("news")
}

model EmergencyNumber {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  cityId       String?  @map("city_id") @db.Uuid
  typeId       String?  @map("type_id") @db.Uuid
  name         String   @db.VarChar(150)
  number       String?  @db.VarChar(50)
  displayOrder Int      @default(0) @map("display_order")
  verified     Boolean  @default(true)
  verifiedById String?  @map("verified_by_id") @db.Uuid
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  city       City?                @relation(fields: [cityId], references: [id], onDelete: Restrict)
  type       EmergencyNumberType? @relation(fields: [typeId], references: [id], onDelete: Restrict)
  verifiedBy User?                @relation(fields: [verifiedById], references: [id], onDelete: SetNull)

  @@index([cityId], map: "idx_emergency_number_city_id")
  @@index([typeId], map: "idx_emergency_number_type_id")
  @@map("emergency_number")
}

model EmergencyNumberType {
  id           String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  slug         String @unique @db.VarChar(50)
  name         String @db.VarChar(150)
  displayOrder Int    @default(0) @map("display_order")

  emergencyNumbers EmergencyNumber[]

  @@map("emergency_number_type")
}

model HelpLink {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  title        String   @db.VarChar(250)
  description  String   @db.VarChar(500)
  url          String   @db.VarChar(2048)
  category     String   @db.VarChar(80)
  verified     Boolean  @default(false)
  verifiedById String?  @map("verified_by_id") @db.Uuid
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  verifiedBy User? @relation(fields: [verifiedById], references: [id], onDelete: SetNull)

  @@index([category], map: "idx_help_link_category")
  @@map("help_link")
}

// ==========================================================================
// Insumos (catálogo + tablas puente)
// ==========================================================================

model SupplyCategory {
  id   String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  slug String @unique @db.VarChar(50)
  name String @db.VarChar(150)

  supplies GeneralSupply[]

  @@map("supply_category")
}

model GeneralSupply {
  id           String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name         String  @db.VarChar(200)
  description  String? @db.VarChar(500)
  displayOrder Int     @default(0) @map("display_order")
  categoryId   String? @map("category_id") @db.Uuid

  category                 SupplyCategory?          @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  collectionCenterSupplies CollectionCenterSupply[]
  shelterSupplies          ShelterSupply[]

  @@index([categoryId], map: "idx_general_supply_category_id")
  @@map("general_supply")
}

model CollectionCenterSupply {
  collectionCenterId String             @map("collection_center_id") @db.Uuid
  supplyId           String             @map("supply_id") @db.Uuid
  relation           SupplyRelationType

  collectionCenter CollectionCenter @relation(fields: [collectionCenterId], references: [id], onDelete: Cascade)
  supply           GeneralSupply    @relation(fields: [supplyId], references: [id], onDelete: Cascade)

  @@id([collectionCenterId, supplyId, relation])
  @@map("collection_center_supply")
}

model ShelterSupply {
  shelterId String             @map("shelter_id") @db.Uuid
  supplyId  String             @map("supply_id") @db.Uuid
  relation  SupplyRelationType

  shelter Shelter       @relation(fields: [shelterId], references: [id], onDelete: Cascade)
  supply  GeneralSupply @relation(fields: [supplyId], references: [id], onDelete: Cascade)

  @@id([shelterId, supplyId, relation])
  @@map("shelter_supply")
}
