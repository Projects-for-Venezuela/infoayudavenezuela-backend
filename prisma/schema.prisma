generator client {
  provider     = "prisma-client"
  output       = "../generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model admin_users {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  email      String   @unique
  password   String
  created_at DateTime @default(dbgenerated("timezone('utc'::text, now())")) @db.Timestamptz(6)
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model centros_acopio {
  id         BigInt   @id @default(autoincrement())
  estado     String
  ciudad     String
  nombre     String
  direccion  String?
  contacto   String?
  hora       String?
  acepta     String[] @default([])
  necesitan  String[] @default([])
  zelle      String?
  pago_movil String?
  verificado Boolean? @default(true)
  created_at DateTime @default(dbgenerated("timezone('utc'::text, now())")) @db.Timestamptz(6)
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model enlaces_ayuda {
  id          BigInt   @id @default(autoincrement())
  titulo      String
  descripcion String
  url         String
  categoria   String
  verificado  Boolean? @default(false)
  created_at  DateTime @default(dbgenerated("timezone('utc'::text, now())")) @db.Timestamptz(6)
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model necesidades_urgentes {
  id            BigInt   @id @default(autoincrement())
  estado        String
  ciudad        String
  lugar         String
  direccion     String?
  que_necesitan String
  contacto      String?
  verificado    Boolean? @default(false)
  created_at    DateTime @default(dbgenerated("timezone('utc'::text, now())")) @db.Timestamptz(6)
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model noticias {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  titulo      String
  descripcion String
  fuente      String?
  estado      String   @default("pendiente")
  created_at  DateTime @default(now()) @db.Timestamptz(6)
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model pacientes {
  id              BigInt   @id @default(autoincrement())
  estado          String
  ciudad          String
  hospital        String
  nombre_paciente String
  cedula          String?
  contacto        String?
  necesitan       String[] @default([])
  estatus         String?  @default("DESCONOCIDO")
  verificado      Boolean? @default(false)
  created_at      DateTime @default(dbgenerated("timezone('utc'::text, now())")) @db.Timestamptz(6)

  @@index([cedula, nombre_paciente], map: "idx_pacientes_identidad")
  @@index([estado, ciudad], map: "idx_pacientes_ubicacion")
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model refugiados {
  id                      String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  nombre_completo         String
  cedula                  String?
  telefono                String?
  refugio_id              String?   @db.Uuid
  estado_salud            String?
  necesidades_especificas String?
  verificado              Boolean?  @default(false)
  created_at              DateTime  @default(dbgenerated("timezone('utc'::text, now())")) @db.Timestamptz(6)
  refugios                refugios? @relation(fields: [refugio_id], references: [id], onUpdate: NoAction)
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model refugios {
  id         String       @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  estado     String
  ciudad     String
  nombre     String
  direccion  String?
  contacto   String?
  capacidad  String?
  acepta     String[]
  necesitan  String[]
  verificado Boolean?     @default(false)
  created_at DateTime?    @default(now()) @db.Timestamptz(6)
  refugiados refugiados[]
}
