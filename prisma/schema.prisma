  ciudades             ciudades[]
  estados_alias        estados_alias[]
  estados_ayuda        estados_ayuda?
  necesidades_urgentes necesidades_urgentes[]
  noticias             noticias[]
  numeros_emergencia   numeros_emergencia[]
