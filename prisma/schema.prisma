generator client {
  provider     = "prisma-client"
  output       = "../generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model admin_users {
  id                   String                 @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  email                String                 @unique
  password             String
  rol                  String                 @default("editor")
  created_at           DateTime               @default(dbgenerated("timezone('utc'::text, now())")) @db.Timestamptz(6)
  centros_acopio       centros_acopio[]
  enlaces_ayuda        enlaces_ayuda[]
  necesidades_urgentes necesidades_urgentes[]
  numeros_emergencia   numeros_emergencia[]
  pacientes            pacientes[]
  refugiados           refugiados[]
  refugios             refugios[]
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model categorias_insumos {
  id           String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  slug         String         @unique
  nombre       String
  icono        String?
  color        String?
  orden        Int            @default(0)
  items_insumo items_insumo[]
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model centros_acopio {
  id             String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  estado_id      String       @db.Uuid
  ciudad_id      String       @db.Uuid
  nombre         String
  direccion      String?
  contacto       String?
  hora           String?
  acepta         String[]     @default([])
  necesitan      String[]     @default([])
  zelle          String?
  pago_movil     String?
  verificado     Boolean      @default(true)
  verificado_por String?      @db.Uuid
  created_at     DateTime     @default(dbgenerated("timezone('utc'::text, now())")) @db.Timestamptz(6)
  updated_at     DateTime     @default(dbgenerated("timezone('utc'::text, now())")) @db.Timestamptz(6)
  ciudades       ciudades     @relation(fields: [ciudad_id], references: [id], onUpdate: NoAction)
  estados        estados      @relation(fields: [estado_id], references: [id], onUpdate: NoAction)
  admin_users    admin_users? @relation(fields: [verificado_por], references: [id], onUpdate: NoAction)

  @@index([ciudad_id], map: "idx_centros_acopio_ciudad_id")
  @@index([estado_id], map: "idx_centros_acopio_estado_id")
  @@index([verificado], map: "idx_centros_acopio_verificado")
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model ciudades {
  id                   String                 @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  estado_id            String                 @db.Uuid
  nombre               String
  centros_acopio       centros_acopio[]
  estados              estados                @relation(fields: [estado_id], references: [id], onUpdate: NoAction)
  hospitales           hospitales[]
  necesidades_urgentes necesidades_urgentes[]
  noticias             noticias[]
  numeros_emergencia   numeros_emergencia[]
  pacientes            pacientes[]
  refugios             refugios[]

  @@unique([estado_id, nombre], map: "ciudades_estado_nombre_key")
  @@index([estado_id], map: "idx_ciudades_estado_id")
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model consejos_donacion {
